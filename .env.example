# ─── Claude API Wrapper — Environment Variables ────────────────────────────────
# Copy to .env and fill in. Never commit .env.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Models ────────────────────────────────────────────────────────────────────
PRIMARY_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=claude-haiku-4-5
MAX_OUTPUT_TOKENS=4096

# ── OAuth2 (client credentials flow) ───────────────────────────────────────────
OAUTH_JWT_SECRET=change-me-to-a-long-random-string-in-production
OAUTH_JWT_ALGORITHM=HS256
OAUTH_TOKEN_EXPIRY_SECONDS=3600

# ── Per-request cost-based routing ─────────────────────────────────────────────
# If estimated request cost exceeds this, route to fallback model instead of primary
COST_ROUTE_THRESHOLD_USD=0.05

# ── Per-API-key budget enforcement ─────────────────────────────────────────────
# Soft limit: downgrade to fallback model once daily spend exceeds this
DAILY_SOFT_BUDGET_USD=5.00
# Hard limit: reject all requests once daily spend exceeds this
DAILY_HARD_BUDGET_USD=10.00

# ── Rate limiting (token bucket, per API key) ──────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=20
RATE_LIMIT_BURST_SIZE=5

# ── Resilience ────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=1.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ── Security ──────────────────────────────────────────────────────────────────
MAX_PROMPT_LENGTH_CHARS=8000
PROMPT_INJECTION_CHECK_ENABLED=true

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
